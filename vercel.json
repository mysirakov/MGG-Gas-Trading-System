{
  "version": 2,
  "builds": [
    {
      "src": "Dashboard.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "Dashboard.py",
          "components.py",
          "database.py",
          "import_csv.py",
          "theme_manager.py",
          "style.css",
          "requirements.txt",
          "pages/**",
          ".streamlit/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "(.*)",
      "dest": "Dashboard.py"
    }
  ]
}
