{
  "version": 2,
  "builds": [
    {
      "src": "Dashboard.py",
      "use": "@vercel/python",
      "config": {
        "excludeFiles": "{attached_assets/**,.git/**,temp_csv/**,data/**,uv.lock,pyproject.toml}"
      }
    }
  ],
  "routes": [
    {
      "src": "(.*)",
      "dest": "Dashboard.py"
    }
  ]
}
